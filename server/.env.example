# ---- Core ----
# Port the server listens on (Railway sets PORT automatically).
PORT=8787
# Comma-separated list of allowed browser origins for CORS.
# In dev this is the Vite frontend; in prod add your Netlify URL.
CORS_ORIGINS=http://localhost:5173

# ---- Database (Railway Postgres) ----
# Railway provides DATABASE_URL automatically when you attach a Postgres service.
DATABASE_URL=postgres://user:password@localhost:5432/sommsavvy

# ---- Auth ----
# Secret used to sign session JWTs. Generate a long random string.
# e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
JWT_SECRET=change-me-to-a-long-random-string
# How long a session token is valid.
JWT_EXPIRES_IN=30d
# Set to "true" in dev to log the email code to the console instead of sending
# a real email. Lets you test auth before wiring Resend.
AUTH_DEV_CODES=true

# ---- Email (Resend) ----
# Create at https://resend.com — free tier covers 3k emails/month.
RESEND_API_KEY=
# Verified sender address, e.g. "SommSavvy <hello@yourdomain.com>".
EMAIL_FROM=SommSavvy <onboarding@resend.dev>

# ---- AI providers ----
# Anthropic (Claude) — editorial text + taste summaries.
ANTHROPIC_API_KEY=
# Google (Gemini) — vision (label/scene reading) + image generation.
GEMINI_API_KEY=
# OpenAI — voice transcription.
OPENAI_API_KEY=

# ---- Scan Web Enrichment ----
# Grounds reverse-scan cards in real web material (tasting notes, value,
# producer context). Provider-neutral; defaults target the You.com Web Search
# API. Leave WEB_SEARCH_API_KEY unset to disable enrichment entirely — scans
# then behave exactly as before. Get a key at https://you.com/platform.
WEB_SEARCH_API_KEY=
# Search endpoint. Default is the You.com v1 search API.
WEB_SEARCH_ENDPOINT=https://ydc-index.io/v1/search
# Number of retrieved results fed to synthesis.
SCAN_ENRICH_MAX_RESULTS=5
# Time bound for the whole enrichment pass (search + synthesis), in ms.
SCAN_ENRICH_TIMEOUT_MS=9000
# Backstop on web-search calls per rolling 60s window across the process.
SCAN_ENRICH_CALLS_PER_MIN=30

# ---- Cellar Search ----
# Natural-language interpretation of the cellar search query. Uses the same AI
# text provider as the rest of the app (no new key). Falls back to the
# substring keyword filter on timeout, error, or when no text provider is set.
# Time bound before falling back to keyword matching, in ms.
CELLAR_SEARCH_TIMEOUT_MS=6000
# Max entries sent to the model; larger cellars truncate to most recent.
CELLAR_SEARCH_MAX_CANDIDATES=120

# Optional model overrides (defaults are current as of this build).
# AI_TEXT_MODEL=claude-haiku-4-5
# AI_VISION_MODEL=gemini-2.5-flash
# AI_IMAGE_MODEL=gemini-2.5-flash-image
# AI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Public base URL of THIS backend. Used to build absolute URLs for stored
# files (generated images, uploads) so the frontend can load them. In dev,
# leave unset to default to http://localhost:PORT. On Railway, set to the
# service's public URL.
PUBLIC_BASE_URL=

# ---- Image storage (Cloudflare R2, added in the storage phase) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sommsavvy
# Public base URL for served objects (R2 public bucket or custom domain).
R2_PUBLIC_BASE_URL=

# ---- Cost Guardrails ----
# Maximum total AI images generated per UTC day across all users.
DAILY_IMAGE_LIMIT=300
# Per signed-in user daily image cap.
USER_DAILY_IMAGE_LIMIT=20
# Per anonymous identity daily image cap.
ANON_DAILY_IMAGE_LIMIT=5
# Per IP daily image backstop (catches device-token rotation).
ANON_IP_DAILY_IMAGE_LIMIT=15
# Images reserved for signed-in users (clamped to DAILY_IMAGE_LIMIT).
SIGNEDIN_RESERVED_IMAGES=90
# Per-IP burst rate limit on AI endpoints (requests per 60s window).
AI_RATE_PER_MIN=12
# Daily AI call limit for anonymous users. 0 = email-required mode.
ANON_DAILY_CALL_LIMIT=0
# Number of portraits Pocket Somm generates per call.
POCKET_SOMM_IMAGE_COUNT=1
