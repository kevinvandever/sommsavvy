{
  "name": "sommsavvy-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/scripts/seed.ts",
    "import": "tsx src/scripts/import-mindstudio.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@google/genai": "^2.10.0",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^17.4.2",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.44.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
